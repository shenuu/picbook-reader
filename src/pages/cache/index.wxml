<!--
  @file pages/cache/index.wxml
  @description 缓存管理页模板

  布局：
  ┌─────────────────────────────────────────┐
  │  📦 缓存管理                              │
  │  ─────────────────────────────────────  │
  │  [LRU 容量进度条] X/20 条               │
  │  命中率: 67%  |  文字: 12 KB  |  音频: 256 KB  |  3 文件   │
  │  ─────────────────────────────────────  │
  │  缓存条目列表（最新→最旧）               │
  │  ┌────────────────────────────────────┐ │
  │  │ 🎵 文字预览前30字…  昨天 14:30   ✕ │ │
  │  │   ← 左滑露出 [📚 加入书架] 按钮    │ │
  │  └────────────────────────────────────┘ │
  │  ...                                    │
  │  ─────────────────────────────────────  │
  │  [清空全部缓存]                          │
  └─────────────────────────────────────────┘

  @author Jamie Park
-->

<view class="page" bindtap="onTapPage">

  <!-- ── 标题 ──────────────────────────────── -->
  <view class="header">
    <text class="header__title">📦 缓存管理</text>
    <text class="header__sub">绘本朗读助手 · LRU 本地缓存</text>
  </view>

  <!-- ── 加载态 ─────────────────────────────── -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中…</text>
  </view>

  <block wx:else>

    <!-- ── LRU 容量进度条 ─────────────────────── -->
    <view class="capacity-card card">
      <view class="capacity-row">
        <text class="capacity-label">缓存容量</text>
        <text class="capacity-count">{{cacheCount}} / {{cacheMaxCount}} 条</text>
      </view>
      <!-- 进度条 -->
      <view class="capacity-track">
        <view
          class="capacity-fill {{capacityPercent >= 90 ? 'capacity-fill--warn' : ''}}"
          style="width: {{capacityPercent}}%"
        ></view>
      </view>
      <!-- 统计指标 -->
      <view class="stat-row">
        <view class="stat-item">
          <text class="stat-value">{{hitRateLabel}}</text>
          <text class="stat-label">命中率</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{cacheSizeKB}} KB</text>
          <text class="stat-label">文字占用</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{audioSizeKB}} KB</text>
          <text class="stat-label">音频占用</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{audioFileCount}}</text>
          <text class="stat-label">音频文件</text>
        </view>
      </view>
    </view>

    <!-- ── 缓存条目列表 ────────────────────────── -->
    <view class="section-title">
      <text>缓存记录</text>
      <text class="section-sub">左滑加入书架 · 点击重播</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{entries.length === 0}}" class="empty-wrap">
      <text class="empty-icon">🗂</text>
      <text class="empty-msg">暂无缓存记录</text>
      <text class="empty-hint">拍照识别绘本后，内容会自动缓存在此</text>
    </view>

    <!-- 条目列表 -->
    <view class="entry-list" wx:else>
      <view
        wx:for="{{entries}}"
        wx:key="pageHash"
        class="entry-row-wrap"
      >
        <!-- 左滑后露出的「加入书架」按钮 -->
        <view
          class="entry-shelf-btn"
          data-hash="{{item.pageHash}}"
          catchtap="onTapAddToShelf"
        >
          <text class="entry-shelf-btn__icon">📚</text>
          <text class="entry-shelf-btn__label">加入书架</text>
        </view>

        <!-- 条目主体（可左滑） -->
        <view
          class="entry-item"
          data-hash="{{item.pageHash}}"
          data-text="{{item.text}}"
          data-index="{{item.index}}"
          style="transform: translateX({{swipeX[item.index] || 0}}px)"
          bindtouchstart="onItemTouchStart"
          bindtouchmove="onItemTouchMove"
          bindtouchend="onItemTouchEnd"
          bindtap="onTapEntry"
        >
          <!-- 左侧音频状态图标 -->
          <view class="entry-icon">
            <text wx:if="{{item.hasAudio}}">🎵</text>
            <text wx:else>📄</text>
          </view>

          <!-- 中间内容 -->
          <view class="entry-body">
            <text class="entry-preview">{{item.preview}}{{item.text.length > 30 ? '…' : ''}}</text>
            <text class="entry-time">{{item.timeLabel}}</text>
          </view>

          <!-- 右侧删除按钮 -->
          <view
            class="entry-delete"
            data-hash="{{item.pageHash}}"
            catchtap="onTapDelete"
          >
            <text class="entry-delete__icon">✕</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ── 清空全部按钮 ────────────────────────── -->
    <view class="footer safe-bottom">
      <button
        class="btn-clear {{entries.length === 0 ? 'btn-clear--disabled' : ''}}"
        bindtap="onTapClearAll"
        disabled="{{clearing || entries.length === 0}}"
        hover-class="btn-clear--hover"
      >
        <text wx:if="{{clearing}}">⏳ 清空中…</text>
        <text wx:else>🗑 清空全部缓存</text>
      </button>
    </view>

  </block>

</view>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- 加入书架 Sheet 弹窗                                     -->
<!-- ═══════════════════════════════════════════════════════ -->
<view
  wx:if="{{showShelfSheet}}"
  class="voice-sheet-mask"
  bindtap="onTapShelfSheetMask"
  catchtouchmove="onShelfSheetPrevent"
></view>

<view class="voice-sheet {{showShelfSheet ? 'voice-sheet--visible' : ''}}">
  <view class="voice-sheet__header">
    <text class="voice-sheet__title">加入书架</text>
    <text class="voice-sheet__close" bindtap="onTapShelfSheetMask">✕</text>
  </view>

  <view wx:if="{{booksLoading}}" class="shelf-sheet__loading">
    <text>加载中…</text>
  </view>

  <block wx:else>
    <view class="shelf-new-btn" bindtap="onTapCreateBook">
      <text class="shelf-new-btn__icon">＋</text>
      <text class="shelf-new-btn__label">新建绘本</text>
    </view>

    <view class="voice-sheet__list" wx:if="{{books.length > 0}}">
      <view
        wx:for="{{books}}"
        wx:key="bookId"
        class="voice-item"
        data-book-id="{{item.bookId}}"
        bindtap="onTapSelectBook"
      >
        <view class="voice-item__avatar">
          <text class="voice-item__emoji">📖</text>
        </view>
        <view class="voice-item__info">
          <text class="voice-item__name">{{item.title}}</text>
          <text class="voice-item__desc">{{item.pages.length}} 页</text>
        </view>
      </view>
    </view>

    <view wx:elif="{{books.length === 0}}" class="shelf-sheet__empty">
      <text>还没有绘本，点上方「新建绘本」创建吧～</text>
    </view>
  </block>
</view>

