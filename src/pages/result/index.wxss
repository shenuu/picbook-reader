/**
 * @file pages/result/index.wxss
 * @description 识别结果页 & 播放器样式
 *
 * @author Jamie Park
 */

/* ── 页面结构 ─────────────────────────────────────────── */

.page {
  min-height: 100vh;
  background-color: var(--color-bg-base);
  display: flex;
  flex-direction: column;
}

/* ── 缓存标签行 ───────────────────────────────────────── */

.cache-badge-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4) var(--space-5) var(--space-2);
}

.cache-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
}

.cache-badge--cached {
  background-color: #E8F5E9;
  color: #2E7D32;
}

.cache-badge--saving {
  background-color: #FFF3E0;
  color: #E65100;
}

.cache-badge--none {
  background-color: var(--color-bg-muted);
  color: var(--color-text-secondary);
}

.from-cache-tag {
  font-size: var(--text-xs);
  color: var(--color-text-disabled);
}

/* 语种提示 badge */
.lang-badge {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-size: var(--text-xs);
}

.lang-badge--english {
  background: #EFF6FF;
  color: #2563EB;
}

.lang-badge--mixed {
  background: #FFF7ED;
  color: #C2410C;
}

/* ── 文字展示区 ───────────────────────────────────────── */

.text-scroll {
  flex: 1;
  padding: 0 var(--space-5) var(--space-4);
  overflow: hidden;
  /* 限制滚动区最大高度，保证播放器始终可见 */
  max-height: calc(100vh - 440rpx);
}

.text-card {
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
}

.text-card__label {
  display: block;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: var(--space-3);
}

.text-card__body {
  display: block;
  font-size: var(--text-lg);
  line-height: 2;
  color: var(--color-text-primary);
  letter-spacing: 2rpx;
  /* 允许多行文字选中复制 */
  user-select: text;
  -webkit-user-select: text;
}

.text-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) 0;
  gap: var(--space-4);
}

.text-empty__icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.text-empty__msg {
  font-size: var(--text-base);
  color: var(--color-text-disabled);
}

/* ── 播放控制区 ───────────────────────────────────────── */

.player {
  background-color: var(--color-bg-card);
  border-top-left-radius: var(--radius-2xl);
  border-top-right-radius: var(--radius-2xl);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  padding: var(--space-6) var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

/* TTS 合成进度条 */
.tts-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.tts-progress-track,
.audio-progress-track {
  width: 100%;
  height: 12rpx;
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.tts-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-text-secondary), var(--color-primary));
  border-radius: var(--radius-full);
  transition: width 300ms ease-out;
  min-width: 4rpx;
}

.tts-progress-label {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  text-align: center;
}

/* 播放进度条 */
.audio-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.audio-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  border-radius: var(--radius-full);
  transition: width 500ms linear;
  min-width: 4rpx;
}

.audio-time-row {
  display: flex;
  justify-content: space-between;
}

.audio-time {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  font-family: var(--font-family-number);
}

/* 错误提示 */
.error-tip {
  font-size: var(--text-sm);
  color: var(--color-error);
  text-align: center;
  line-height: 1.6;
}

/* ── 播放主按钮 ───────────────────────────────────────── */

.btn-play {
  width: 100%;
  height: 104rpx;
  font-size: var(--text-xl);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  border-radius: var(--radius-full) !important;
  border: none !important;
  box-shadow: var(--shadow-primary) !important;
  transition: transform var(--duration-fast) ease, opacity var(--duration-fast) ease;
}

.btn-play::after {
  border: none;
}

/* idle: 橙色 */
.btn-play--idle {
  background-color: var(--color-primary) !important;
  color: #fff !important;
}

/* loading: 灰色禁用 */
.btn-play--loading {
  background-color: var(--color-text-disabled) !important;
  color: #fff !important;
  box-shadow: none !important;
}

/* playing: 橙色 + 脉冲动画 */
.btn-play--playing {
  background-color: var(--color-primary) !important;
  color: #fff !important;
  animation: pulse 1.4s infinite;
}

/* finished: 蓝色 */
.btn-play--finished {
  background-color: #1976D2 !important;
  color: #fff !important;
  box-shadow: 0 8rpx 24rpx rgba(25, 118, 210, 0.40) !important;
}

/* error: 红色 */
.btn-play--error {
  background-color: var(--color-error) !important;
  color: #fff !important;
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.35) !important;
}

.btn-play--hover {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-play__icon {
  font-size: 48rpx;
}

@keyframes pulse {
  0%   { box-shadow: var(--shadow-primary); }
  50%  { box-shadow: 0 0 0 16rpx rgba(255, 112, 67, 0.25); }
  100% { box-shadow: var(--shadow-primary); }
}

/* ── 重播按钮 ─────────────────────────────────────────── */

.btn-replay {
  width: 100%;
  height: 72rpx;
  font-size: var(--text-base);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full) !important;
  background-color: transparent !important;
  color: var(--color-primary) !important;
  border: 2rpx solid var(--color-primary) !important;
  box-shadow: none !important;
}

.btn-replay::after {
  border: none;
}

.btn-replay--hover {
  background-color: var(--color-primary-light) !important;
}

/* ── paused 状态按钮样式（蓝绿色，区别于 playing） */
.btn-play--paused {
  background-color: #00897B !important;
  color: #fff !important;
  box-shadow: 0 8rpx 24rpx rgba(0, 137, 123, 0.40) !important;
}

/* ── Phase 2: 声音切换按钮行 ─────────────────────── */

.voice-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 var(--space-1);
}

/* 当前声音展示条（可点击，打开声音面板） */
.voice-current {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-full);
  padding: 8rpx 24rpx;
  cursor: pointer;
}

.voice-current__emoji {
  font-size: 36rpx;
}

.voice-current__label {
  font-size: var(--text-sm);
  color: var(--color-text-primary);
  font-weight: 600;
}

.voice-current__arrow {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  transform: rotate(180deg);
  display: inline-block;
}

/* ── Phase 2: 声音选择 Sheet（底部弹窗） ─────────── */

/* 遮罩层 */
.voice-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 100;
}

/* Sheet 本体（默认隐藏在屏幕底部） */
.voice-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 101;
  background-color: var(--color-bg-card);
  border-top-left-radius: var(--radius-2xl);
  border-top-right-radius: var(--radius-2xl);
  padding: var(--space-6) var(--space-5);
  padding-bottom: calc(var(--space-8) + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.12);
}

/* 显示时滑入 */
.voice-sheet--visible {
  transform: translateY(0);
}

/* Sheet 标题行 */
.voice-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-6);
}

.voice-sheet__title {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.voice-sheet__close {
  font-size: var(--text-xl);
  color: var(--color-text-secondary);
  padding: var(--space-2);
}

/* 声音列表 */
.voice-sheet__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

/* 单个声音条目 */
.voice-item {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4) var(--space-4);
  border-radius: var(--radius-xl);
  background-color: var(--color-bg-base);
  border: 2rpx solid transparent;
  transition: background-color 0.2s ease, border-color 0.2s ease;
}

/* 选中状态 */
.voice-item--active {
  background-color: #FFF3E0;
  border-color: var(--color-primary);
}

/* 头像容器 */
.voice-item__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.voice-item__emoji {
  font-size: 56rpx;
}

/* 声音信息 */
.voice-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.voice-item__name {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

.voice-item__desc {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
}

/* 选中勾 */
.voice-item__check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: var(--text-base);
  font-weight: 700;
  flex-shrink: 0;
}

/* 安全区 */
.safe-bottom {
  padding-bottom: calc(var(--space-6) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-6) + env(safe-area-inset-bottom));
}
