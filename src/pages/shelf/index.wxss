/**
 * @file pages/shelf/index.wxss
 * @description 书架页样式 - 左滑删除
 */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #FFFDF8;
}

/* ── 工具栏 ── */
.toolbar {
  padding: 24rpx 32rpx 16rpx;
}

.btn-create {
  background: #FF7043;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border: none;
  font-weight: 600;
}

/* ── 空/加载 ── */
.hint {
  padding: 120rpx 32rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
  gap: 24rpx;
}

.empty__icon {
  font-size: 96rpx;
}

.empty__text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.7;
  white-space: pre-line;
}

/* ── 列表 ── */
.list {
  flex: 1;
}

/* ── 左滑容器：撑满宽度 + overflow hidden ── */
.row-wrap {
  position: relative;
  overflow: hidden;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
}

/* ── 删除按钮（绝对定位在右侧外） ── */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E53935;
  border-radius: 0 20rpx 20rpx 0;
  z-index: 1;
}

.delete-btn__icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  font-size: var(--text-sm);
  color: #fff;
}

/* ── 条目主体 ── */
.book-item {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  gap: 24rpx;
  transition: transform 0.2s ease;
}

.book-item__icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.book-item__info {
  flex: 1;
  min-width: 0;
}

.book-item__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-item__meta {
  font-size: 24rpx;
  color: #888;
  margin-top: 6rpx;
  display: block;
}

.book-item__rename {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  opacity: 0.6;
}

.safe-bottom {
  height: 48rpx;
}
